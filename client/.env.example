# Add or remove pairs here — no code changes required.
VITE_PRODUCTS=BTC-USD,ETH-USD,XRP-USD,LTC-USD

# WebSocket server URL
VITE_WS_URL=ws://localhost:3001/ws

# Max number of matches to keep in the blotter
VITE_MAX_MATCHES=200

# Order book levels to display per side (bids/asks)
VITE_ORDER_BOOK_LEVELS=15

# Number of trade rows to show in the Match View blotter
VITE_MATCH_VISIBLE_ROWS=15

# Locale for number and time formatting (BCP 47 language tag)
VITE_LOCALE=en-US

# How often (ms) to flush order book updates to React state
VITE_ORDER_BOOK_FLUSH_MS=50

# How often (ms) to flush incoming trades to React state
VITE_MATCH_FLUSH_MS=100

# How long (ms) to wait before reconnecting after a disconnect
VITE_RECONNECT_MS=3000
