# Server Configuration
SERVER_PORT=3001

# Comma-separated list of Coinbase product pairs to support.
# Add or remove pairs here — no code changes required.
# Format: BASE-QUOTE (e.g. BTC-USD,ETH-USD,SOL-USD,DOGE-USD)
ALLOWED_PRODUCTS=BTC-USD,ETH-USD,XRP-USD,LTC-USD
CLIENT_ORIGIN=http://localhost:3000

# Coinbase WebSocket Feed
COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com

# Order Book Settings
# Number of top bids/asks levels to send to clients
ORDER_BOOK_DEPTH=25

# Performance Settings
# How often (ms) to push order book snapshots to subscribed clients
ORDER_BOOK_BROADCAST_INTERVAL_MS=50

# Max number of unique trade IDs to track for server-side deduplication
MATCH_DEDUP_SIZE=2000

# WebSocket heartbeat interval (ms) — terminates silently dead connections
HEARTBEAT_INTERVAL_MS=30000

# Reconnection Settings
# Max reconnection delay in ms (uses exponential backoff)
RECONNECT_MAX_DELAY_MS=30000
# Base reconnect delay in ms
RECONNECT_BASE_DELAY_MS=1000

# Debug: print every raw Coinbase WS message to stdout (true|false)
DEBUG_WS=false

# Pino log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Set to "production" for JSON log output (no pretty-printing)
NODE_ENV=development

# ── Coinbase API Credentials (optional) ──────────────────────────────────────
# level2_batch and matches channels are public — no credentials needed.
# Add these only if you need access to private channels in future.
#
# COINBASE_API_KEY=your_api_key_here
# COINBASE_API_SECRET=your_api_secret_here
# COINBASE_API_PASSPHRASE=your_api_passphrase_here
