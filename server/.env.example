# Server Configuration
SERVER_PORT=3001

# Format: BASE-QUOTE (e.g. BTC-USD,ETH-USD,SOL-USD,DOGE-USD)
ALLOWED_PRODUCTS=BTC-USD,ETH-USD,XRP-USD,LTC-USD

CLIENT_ORIGIN=http://localhost:3000

# Coinbase WebSocket Feed
COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com

# Number of top bids/asks levels to send to clients
ORDER_BOOK_DEPTH=25

# How often (ms) to push order book snapshots to subscribed clients
ORDER_BOOK_BROADCAST_INTERVAL_MS=50

# Max number of unique trade IDs to track for server-side deduplication
MATCH_DEDUP_SIZE=2000

# WebSocket heartbeat interval (ms) — terminates silently dead connections
HEARTBEAT_INTERVAL_MS=30000

# Max reconnection delay in ms (uses exponential backoff)
RECONNECT_MAX_DELAY_MS=30000

# Base reconnect delay in ms
RECONNECT_BASE_DELAY_MS=1000

DEBUG_WS=false

LOG_LEVEL=info

NODE_ENV=development

